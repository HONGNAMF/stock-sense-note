# MVP에서는 실제 API 키 없이 mock data로 동작합니다.
# 추후 실제 API 연결 시 아래 값을 채워 사용하세요.

NEXT_PUBLIC_APP_NAME=Sensefolio

# Supabase cloud sync
# Vercel Project Settings > Environment Variables에 같은 값을 넣으면
# 닉네임 로그인, 관심종목, 메모, 판단 기록, 매수/매도 기록이 다른 기기와 동기화됩니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only
OPENAI_API_KEY=
STOCK_API_KEY=
NEWS_API_KEY=
